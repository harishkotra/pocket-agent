# ── Required: Stripe ────────────────────────────────────────
# Get a test key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Required: On-chain ───────────────────────────────────────
# RPC URL for the testnet (Base Sepolia or Sepolia)
RPC_URL=https://sepolia.base.org
NETWORK=base-sepolia          # 'base-sepolia' or 'sepolia'

# Address of the deployed PocketAgentCredit contract
CREDIT_TOKEN_ADDRESS=0x...

# Facilitator wallet private key (must have MINTER_ROLE + BURNER_ROLE on the token)
FACILITATOR_PRIVATE_KEY=0x...

# The corresponding address (for demo/scripts)
FACILITATOR_ADDRESS=0x...

# ── Server ports ────────────────────────────────────────────
FACILITATOR_URL=http://localhost:3020
FACILITATOR_PORT=3020
AGENT_SERVER_URL=http://localhost:3010
AGENT_SERVER_PORT=3010
